APP_ENV=development
APP_SECRET=replace-with-a-long-random-string
ADMIN_TOKEN=replace-with-a-separate-admin-token
BASE_URL=http://localhost:8000
DATABASE_PATH=data/travel_notifs.db
DRY_RUN=true

# Google Places (not needed in demo mode)
GOOGLE_MAPS_API_KEY=
GOOGLE_ROUTES_API_KEY=

# Telegram (not needed while DRY_RUN=true)
TELEGRAM_BOT_TOKEN=

# Optional email delivery
RESEND_API_KEY=
EMAIL_FROM=Transit Dispatch <alerts@example.com>
